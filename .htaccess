# ============================================================
#  TAZVERDE LTD — .htaccess
#  Place in the ROOT folder (same level as index.html)
# ============================================================

# ── RewriteEngine — declared ONCE ────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── CLEAN URLs ──────────────────────────────────────────
    # Remove trailing slash (unless directory)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^/]+)/$ http://%{HTTP_HOST}/$1 [R=301,L]

    # Redirect .html requests to extensionless URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.html
    RewriteRule ^/?(.*)\.html$ /$1 [L,R=301]

    # Redirect .php requests to extensionless URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php
    RewriteRule ^/?(.*)\.php$ /$1 [L,R=301]

    # Resolve extensionless URL → .html file
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [NC,L]

    # Resolve extensionless URL → .php file
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [NC,L]
</IfModule>


# ── GZIP COMPRESSION ─────────────────────────────────────────
# Compresses HTML, CSS, JS, JSON before sending — cuts transfer
# size by 60-80% for text-based files.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>


# ── BROWSER CACHE HEADERS ────────────────────────────────────
#
#  Images/CSS/JS/fonts → 1 year
#    Safe because upload.php generates timestamped filenames
#    (e.g. 1778000000_coffee-beans.webp) so old cached files
#    are never served after a CMS update.
#
#  content.json → 5 minutes
#    Short so CMS updates appear quickly for all visitors.
#
#  HTML → 1 hour
#    Balanced: repeat visitors get a cached page but changes
#    propagate within the hour.
#
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/html                 "access plus 1 hour"

    <Files "content.json">
        ExpiresByType application/json      "access plus 5 minutes"
    </Files>

    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/jpg                 "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"

    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"

    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
</IfModule>


# ── CACHE-CONTROL HEADERS ────────────────────────────────────
<IfModule mod_headers.c>

    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "^content\.json$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # Security headers
    Header set X-Content-Type-Options  "nosniff"
    Header set X-Frame-Options         "SAMEORIGIN"
    Header set Referrer-Policy         "strict-origin-when-cross-origin"

    # Keep-alive — reuses TCP connections across requests
    Header set Connection keep-alive

</IfModule>
